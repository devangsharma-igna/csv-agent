# Azure OpenAI
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_DEPLOYMENT_NAME=

# Supabase
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# REQUIRED for MCP server versions >= 0.4
# This is a Personal Access Token (PAT) — NOT the service role key.
# The two are completely different credentials:
#   - Service role key  → authenticates direct REST/PostgREST calls
#   - Personal Access Token → authenticates the Supabase Management API (used by MCP)
#
# Generate your PAT at: https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=your-personal-access-token

# REQUIRED for CSV upload feature (direct PostgreSQL write connection)
# MCP connector is read-only; this separate URI is used by SQLAlchemy for
# CREATE TABLE / INSERT operations when uploading CSV files.
#
# Find it in: Supabase Dashboard → Settings → Database → Connection string → URI
# Format:  postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
# Use the SESSION POOLER URL (NOT the Direct connection URL).
# The Direct URL uses IPv6 and fails on most networks.
# Find it: Supabase Dashboard → Settings → Database → Connection Pooling → Session mode (port 5432)
SUPABASE_DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres
